{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "mistral:latest": {
          "name": "mistral:latest"
        },
        "qwen3:8b": {
          "name": "qwen3:8b"
        },
        "llama3.1:8b": {
          "name": "llama3.1:8b"
        }
      }
    }
  }
}
